{
  "name": "@marcalexiei/devtools-wiki",
  "private": true,
  "version": "1.0.0",
  "description": "Static site with a list of development resources",
  "keywords": [],
  "author": "Marco Pasqualetti @marcalexiei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcalexiei/devtools-wiki.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.0.6+sha512.97f906e1da2bedac3df83cadae04b4753a130092dd49d55cd36825ad3e623e9df3f97754f8f259e699172a360fac569acf2f908e7732bdae3eddb2dcf7e121fd",
  "scripts": {
    "dev": "vite",
    "dev:typecheck": "pnpm run typecheck -- --watch",
    "build": "vite build",
    "build:preview": "pnpm run build && vite preview",
    "test": "vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "check-all": "pnpm run \"/^(build|lint|format|typecheck)$/\" && pnpm run test --run"
  },
  "dependencies": {
    "@solidjs/router": "0.15.3",
    "@tanstack/solid-query": "5.100.9",
    "solid-js": "1.9.7",
    "zod": "4.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@marcalexiei/biome-config": "1.2.1",
    "@solidjs/testing-library": "0.8.10",
    "@testing-library/jest-dom": "6.6.4",
    "@types/node": "24.1.0",
    "happy-dom": "18.0.1",
    "sass-embedded": "1.89.2",
    "typescript": "5.8.3",
    "vite": "7.0.6",
    "vite-plugin-solid": "2.11.12",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
